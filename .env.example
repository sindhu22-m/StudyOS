# StudyOS Environment Configuration Example
# Copy this file to '.env' in the root directory and update with your own keys

# Set your Gemini API key. 
# Switch to a billing-enabled account in Google AI Studio for higher quotas (1000 RPM, unlimited RPD).
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override the model
# GEMINI_MODEL=gemini-2.5-flash
